# --- Frontend (Vite) ---
# Base URL del backend. En producción con backend + SPA en el mismo servicio Railway,
# dejar en "/api" para usar rutas relativas. Para desarrollo local queda cubierto
# por el proxy de Vite (ver vite.config.ts).
VITE_API_URL=/api

# --- Backend (Express) ---
# Conexión a PostgreSQL. En Railway se inyecta automáticamente por el plugin.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret para firmar JWTs de sesión. Usar algo largo y aleatorio.
JWT_SECRET=replace-me-with-a-long-random-string

# Expiración del JWT (formato de ms/zeit — ej. "7d", "12h").
JWT_EXPIRES_IN=7d

# Puerto — Railway lo inyecta como PORT. En local se puede dejar en 3000.
PORT=3000

# "production" activa el servido de archivos estáticos desde dist/.
NODE_ENV=development

# Orígenes permitidos por CORS (coma-separado). Vacío = permite todo (dev).
# En prod: https://beast-hub-command.up.railway.app (o el dominio real).
CORS_ORIGIN=
